{
  "name": "cundiconnection",
  "version": "1.0.0",
  "private": true,
  "description": "Cundiconnection — a dark vibrant campus matching app for Universidad de Cundinamarca email-verified students.",
  "workspaces": ["client", "server"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "install:all": "npm install",
    "server": "npm run dev --workspace=server",
    "client": "npm run dev --workspace=client",
    "build": "npm run build --workspace=client",
    "start": "npm run start --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
