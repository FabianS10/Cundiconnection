# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Security ─────────────────────────────────────────────
# Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-secret

# ── Frontend / CORS ──────────────────────────────────────
# Local:
CLIENT_ORIGIN=http://localhost:5173

# Production example:
# CLIENT_ORIGIN=https://cundiconnection.netlify.app

# ── First Admin Bootstrap ────────────────────────────────
# Used only to create the first admin account.
# Do NOT use weak passwords in production.
FIRST_ADMIN_EMAIL=your-admin-email@ucundinamarca.edu.co
FIRST_ADMIN_PASSWORD=replace-this-with-a-strong-admin-password

# ── Campus Verification ──────────────────────────────────
ALLOWED_DOMAIN=ucundinamarca.edu.co

# ── Database ─────────────────────────────────────────────
# If using local SQLite:
DATABASE_URL=file:./dev.db

# If using Railway/Supabase/Postgres:
# DATABASE_URL=postgresql://user:password@host:port/database